# Backend environment example
# Copy this file to backend/.env and fill in the real values.

# Database
# Uses SQLite by default if DATABASE_URL is omitted.
# DATABASE_URL=sqlite:///./sftr_unmatch.db

# LLM provider configuration
# Supported values: ollama | anthropic | openai
LLM_PROVIDER=anthropic

# Active profile fallback.
LLM_MODEL=claude-sonnet-4-6

# Provider-specific secrets
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional generic fallback for legacy config.
LLM_API_KEY=

# Provider endpoints
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434
LLM_BASE_URL=

# Local Ollama example:
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma4:e2b
# OLLAMA_BASE_URL=http://localhost:11434
# If the backend runs in the docker-compose stack with the bundled Ollama service:
# OLLAMA_BASE_URL=http://ollama:11434
# If the backend runs inside Docker and Ollama runs on the host machine instead:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM_API_KEY=
